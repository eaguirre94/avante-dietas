# ─── Base de datos (PostgreSQL 17) ───────────────────────────────
# Local (docker compose): usuario avante / pass avante / schema dietas
DATABASE_URL="postgresql://avante:avante@localhost:5432/dietas?schema=dietas"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────
# Generar: openssl rand -base64 32   (o npx auth secret)
AUTH_SECRET="REEMPLAZAR-por-un-secreto-largo-y-aleatorio"
AUTH_TRUST_HOST="true"

# ─── Candado de red (marcaje solo desde WiFi/red de Avante) ──────
# On-prem: subredes privadas de cada sede.
# En la nube/K8s: poner aquí la(s) IP pública(s) fija(s) de cada sede.
AVANTE_CIDRS="192.168.8.0/22,192.168.100.0/22"
SEDES='{"192.168.8.0/22":"Centro Medico","192.168.100.0/22":"Hospital Especializado"}'

# Detrás de ingress/reverse-proxy (K8s) = true. Servidor directo en LAN = false.
TRUST_FORWARDED_FOR="true"
ALLOW_LOOPBACK="true"

# ─── Reglas de negocio ───────────────────────────────────────────
AUTO_APPROVE_DEVICES="true"
ALLOW_SELF_REGISTER="false"
TIMEZONE_OFFSET_HOURS="-6"

# DEV_MODE=true acepta cualquier red privada (para construir/probar).
DEV_MODE="true"
