{
  "name": "avante-dietas",
  "version": "3.0.0",
  "private": true,
  "description": "Módulo de Dietas Hospitalarias AVANTE — dietas clínicas, cocina/KDS, inventario FEFO y cargos (stack empresarial)",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @avante/db generate",
    "db:push": "pnpm --filter @avante/db push",
    "db:seed": "pnpm --filter @avante/db seed",
    "db:migrate-legacy": "pnpm --filter @avante/db migrate-legacy",
    "postgres:up": "docker compose up -d postgres",
    "postgres:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "sharp"]
  }
}
